# Required: WhatsApp auth payload (base64 JSON or raw JSON)
SESSION_ID=

# Optional: load session from file instead of SESSION_ID
# SESSION_FILE=./session.txt

# Local SQLite database file used by the bot.
SQLITE_PATH=./data/bot.db

BOT_NAME=Desam WABot
PREFIX=.
MODE=public
OWNER_NUMBER=
TIMEZONE=Africa/Accra
AUTO_READ=off
AUTO_STATUS_VIEW=off
ANTI_CALL=on
ANTI_CALL_MSG=Calls are not allowed. This bot rejects all calls.
AUTO_BIO=off
AUTO_BIO_MSG=🤖 Desam WABot | {time} | {date}
CHATBOT=off
DEVICE_MODE=Android
LOG_LEVEL=info
DEBUG_LOGS=off

# Optional advanced flags
# ACCEPT_ANY_SESSION=off
