# Optional bootstrap: WhatsApp auth payload (base64 JSON or raw JSON)
# If empty, the bot will print a QR for first-time linked-device pairing and persist creds in auth_state/.
SESSION_ID=

# Optional: load session from file instead of SESSION_ID
# SESSION_FILE=./session.txt

# Optional: directory containing tokenized session files (e.g., desam_xxx -> desam_xxx.txt)
# SESSION_VAULT_DIR=/opt/desam-bots/sessions

# Local SQLite database file used by the bot.
SQLITE_PATH=./data/bot.db

BOT_NAME=Desam WABot
PREFIX=.
MODE=public
OWNER_NUMBER=
TIMEZONE=Africa/Accra
AUTO_READ=off
AUTO_STATUS_VIEW=on
ANTI_CALL=off
ANTI_CALL_MSG=Calls are not allowed. This bot rejects all calls.
AUTO_BIO=off
AUTO_BIO_MSG=🤖 Desam WABot | {time} | {date}
CHATBOT=off
DEVICE_MODE=Android
BROWSER_VERSION=120.0.0
LOG_LEVEL=info
DEBUG_LOGS=off

# Optional advanced flags
# ACCEPT_ANY_SESSION=off

# Optional API keys (commands still work with fallbacks where possible)
# TENOR_API_KEY=
# GIPHY_API_KEY=
# UNSPLASH_ACCESS_KEY=
# OMDB_API_KEY=
# SCREENSHOTLAYER_ACCESS_KEY=
# GNEWS_API_KEY=
# CURRENTS_API_KEY=
# REMOVEBG_API_KEY=
# OCR_API_KEY=

# SMMRaja API key — required for TikTok boosting (.ttviews, .ttlikes, .ttcheck)
# Get yours at: https://smmraja.com → My Account → API
SMMRAJA_API_KEY=
