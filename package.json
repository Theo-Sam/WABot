{
  "name": "desam-wabot",
  "version": "2.0.0",
  "description": "Desam WABot - Multi-Device WhatsApp Bot with 200+ commands",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "doctor": "node scripts/doctor.js",
    "verify:status-cache": "node scripts/verify-status-cache.js",
    "backup:state": "node scripts/backup-state.js",
    "restore:state": "node scripts/restore-state.js",
    "start:24x7": "pm2 start ecosystem.config.cjs --only wabot",
    "stop:24x7": "pm2 stop wabot && pm2 delete wabot",
    "status:24x7": "pm2 status wabot",
    "logs:24x7": "pm2 logs wabot --lines 100",
    "save:24x7": "pm2 save"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "baileys",
    "multi-device",
    "desam"
  ],
  "author": "Desam Tech",
  "license": "MIT",
  "engines": {
    "node": ">=20 <25"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "api-dylux": "^1.8.6",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.6.1",
    "duckduckgo-ai-chat": "^1.0.0",
    "express": "^5.2.1",
    "facebook-video-downloader": "^1.0.1",
    "file-type": "^16.5.4",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "g4f": "^1.4.6",
    "google-play-scraper": "^10.1.2",
    "insta-fetcher": "^1.4.0",
    "instagram-url-direct": "^2.0.7",
    "mime-types": "^2.1.35",
    "moment-timezone": "^0.5.48",
    "node-cache": "^5.1.2",
    "node-webpmux": "^3.2.1",
    "openai": "^6.33.0",
    "pino": "^9.14.0",
    "play-dl": "^1.9.7",
    "pm2": "^5.4.3",
    "qrcode-terminal": "^0.12.0",
    "remove.bg": "^1.3.0",
    "replicate": "^1.4.0",
    "sharp": "^0.33.5",
    "tesseract.js": "^7.0.0",
    "youtube-dl-exec": "^3.1.4"
  }
}
